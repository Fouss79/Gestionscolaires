<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400" prefWidth="600" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.StatutController">
   <children>
      <Label layoutX="50" layoutY="50" text="Nom du Statut :" />
      <TextField fx:id="txtStatut" layoutX="180" layoutY="45" prefWidth="200" promptText="ex: Eleve" />
      <Button layoutX="180" layoutY="90" onAction="#ajouterNiveau" style="-fx-background-color: green; -fx-text-fill: white;" text="Ajouter Statut" />
      <TableView fx:id="tableStatut" layoutX="50" layoutY="150" prefHeight="200" prefWidth="500">
         <columns>
            <TableColumn fx:id="colNom" prefWidth="480" text="Nom du Statut" />
         </columns>
      </TableView>
   </children>
</AnchorPane>
