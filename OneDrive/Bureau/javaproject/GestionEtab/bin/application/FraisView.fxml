<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400" prefWidth="700" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21" fx:controller="application.FraisController">

    <!-- Motif -->
    <Label layoutX="20" layoutY="20" text="Motif:" />
    <ComboBox fx:id="cmbMotif" layoutX="100" layoutY="16" prefWidth="180" />

    <!-- Annee scolaire -->
    <Label layoutX="320" layoutY="20" text="Année Scolaire:" />
    <ComboBox fx:id="cmbAnneeScolaire" layoutX="440" layoutY="16" prefWidth="180" />

    <!-- Montant -->
    <Label layoutX="20" layoutY="60" text="Montant:" />
    <TextField fx:id="txtMontant" layoutX="100" layoutY="56" prefWidth="120" promptText="ex: 25000" />

    <!-- Bouton ajouter -->
    <Button layoutX="250" layoutY="56" onAction="#ajouterFrais" style="-fx-background-color: green; -fx-text-fill: white;" text="Ajouter" />

    <!-- Table -->
    <TableView fx:id="tableFrais" layoutY="93.0" prefHeight="270" prefWidth="712.0">
        <columns>
            <TableColumn fx:id="colMotif" prefWidth="200" text="Motif" />
            <TableColumn fx:id="colMontant" prefWidth="160.66665649414062" text="Montant" />
            <TableColumn fx:id="colAnnee" prefWidth="167.33334350585938" text="Année Scolaire" />
         <TableColumn fx:id="colNiveau" prefWidth="122.6666259765625" text="Niveau" />
        </columns>
    </TableView>
   <ComboBox fx:id="cmbNiveau" layoutX="442.0" layoutY="55.0" prefWidth="180" />
   <Label layoutX="324.0" layoutY="63.0" text="Niveau" />

</AnchorPane>
