<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="657.0" prefWidth="1283.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.EleveController">

    <!-- 🔹 Formulaire -->
    <Label layoutX="491.0" layoutY="145.0" text="Nom:" />
    <TextField fx:id="txtNom" layoutX="595.0" layoutY="140.0" prefWidth="200" />

    <Label layoutX="489.0" layoutY="185.0" text="Prénom:" />
    <TextField fx:id="txtPrenom" layoutX="597.0" layoutY="180.0" prefWidth="200" />

    <Label layoutX="489.0" layoutY="225.0" text="Date de Naissance:" />
    <DatePicker fx:id="dpNaissance" layoutX="598.0" layoutY="221.0" prefWidth="200" />

    <Label layoutX="489.0" layoutY="265.0" text="Adresse:" />
    <TextField fx:id="txtAdresse" layoutX="597.0" layoutY="261.0" prefWidth="200" />

    <Label layoutX="489.0" layoutY="305.0" text="Téléphone:" />
    <TextField fx:id="txtTelephone" layoutX="597.0" layoutY="301.0" prefWidth="200" />

    <Label layoutX="492.0" layoutY="345.0" text="Classe:" />
    <ComboBox fx:id="cbClasse" layoutX="600.0" layoutY="341.0" prefWidth="200" />

    <!-- Bouton -->
    <Button layoutX="556.0" layoutY="463.0" onAction="#ajouterEleve" prefWidth="200" style="-fx-background-color: green;" text="Enregistrer Élève" textFill="#f4eaea">
      <font>
         <Font name="System Bold" size="14.0" />
      </font></Button>
   <Label layoutX="1.0" layoutY="1.0" prefHeight="51.0" prefWidth="1283.0" style="-fx-background-color: #2C3E50;" text="                                                   INSCRIPTIONS" textFill="#f4f1f1">
      <font>
         <Font name="System Bold" size="23.0" />
      </font>
   </Label>
   <ComboBox fx:id="cbSexe" layoutX="599.0" layoutY="381.0" prefWidth="200" />
   <Label layoutX="494.0" layoutY="386.0" text="Sexe" />
   <ComboBox fx:id="cbStatut" layoutX="599.0" layoutY="420.0" prefWidth="200" />
   <Label layoutX="499.0" layoutY="427.0" text="Statut" />

</AnchorPane>
