<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>

<AnchorPane xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="application.TypeController">

    <children>

        <Label text="Gestion des Types"
               layoutX="200" layoutY="20"
               style="-fx-font-size:18px; -fx-font-weight:bold;" />

        <TextField fx:id="txtNom"
                   layoutX="150" layoutY="60"
                   prefWidth="250"
                   promptText="Nom du type (RECETTE / DEPENSE)" />

        <HBox layoutX="150" layoutY="100" spacing="10">
            <children>
                <Button text="Ajouter" onAction="#ajouterType"/>
                <Button text="Modifier" onAction="#modifierType"/>
                <Button text="Supprimer" onAction="#supprimerType"/>
            </children>
        </HBox>

        <TableView fx:id="tableType"
                   layoutX="100" layoutY="150"
                   prefWidth="400" prefHeight="250">

            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="80"/>
                <TableColumn fx:id="colNom" text="Nom" prefWidth="300"/>
            </columns>

        </TableView>

    </children>

</AnchorPane>