<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>

<AnchorPane xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="application.MotifController">

    <children>

        <Label text="Gestion des Motifs"
               layoutX="200" layoutY="20"
               style="-fx-font-size:18px; -fx-font-weight:bold;" />

        <Label text="Nom :" layoutX="100" layoutY="70"/>
        <TextField fx:id="txtNom"
                   layoutX="160" layoutY="65"
                   prefWidth="250"/>

        <Label text="Type :" layoutX="100" layoutY="110"/>
        <ComboBox fx:id="cbType"
                  layoutX="160" layoutY="105"
                  prefWidth="250"/>

        <HBox layoutX="160" layoutY="150" spacing="10">
            <children>
                <Button text="Ajouter" onAction="#ajouterMotif"/>
                <Button text="Modifier" onAction="#modifierMotif"/>
                <Button text="Supprimer" onAction="#supprimerMotif"/>
            </children>
        </HBox>

        <TableView fx:id="tableMotif"
                   layoutX="80" layoutY="200"
                   prefWidth="450" prefHeight="250">

            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colNom" text="Nom" prefWidth="180"/>
                <TableColumn fx:id="colType" text="Type" prefWidth="200"/>
            </columns>

        </TableView>

    </children>

</AnchorPane>