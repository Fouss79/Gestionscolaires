<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIcon?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="657.0" prefWidth="1283.0" style="-fx-background-image: url('/ressources/images/classe1.jpg'); -fx-background-size: cover; -fx-background-position: center;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"  fx:controller="application.PaiementEleveController">

    <Label layoutX="360" layoutY="20" style="-fx-font-size:22px;-fx-font-weight:bold;" text="GESTION DES PAIEMENTS" />

    <!-- Année -->
    <ComboBox fx:id="comboAnnee" layoutX="357.0" layoutY="64.0" prefWidth="150" />

    <!-- Élève -->
    <Label layoutX="277.0" layoutY="112.0" text="Élève :" />
    <ComboBox fx:id="cbEleve" layoutX="357.0" layoutY="107.0" onAction="#chargerSituation" prefWidth="250" />

    <!-- Frais -->
    <Label layoutX="277.0" layoutY="152.0" text="Frais :" />
    <ComboBox fx:id="cbFrais" layoutX="357.0" layoutY="147.0" onAction="#chargerSituation" prefWidth="250" />

    <!-- Situation -->
    <Label layoutX="657.0" layoutY="112.0" text="Total :" />
    <TextField fx:id="txtTotal" editable="false" layoutX="737.0" layoutY="107.0" />

    <Label layoutX="657.0" layoutY="152.0" text="Déjà payé :" />
    <TextField fx:id="txtPaye" editable="false" layoutX="737.0" layoutY="147.0" />

    <Label layoutX="657.0" layoutY="194.0" text="Reste :" />
    <TextField fx:id="txtReste" editable="false" layoutX="737.0" layoutY="187.0" />

    <!-- Paiement -->
    <Label layoutX="277.0" layoutY="212.0" text="Montant payer :" />
    <TextField fx:id="txtMontant" layoutX="357.0" layoutY="207.0" prefWidth="150" />

    <Label layoutX="277.0" layoutY="252.0" text="Mode :" />
    <ComboBox fx:id="cbMode" layoutX="357.0" layoutY="247.0" prefWidth="150" />

    <Button layoutX="357.0" layoutY="292.0" onAction="#ajouterPaiement" text="Enregistrer paiement" />

    <Button layoutX="537.0" layoutY="292.0" onAction="#imprimerRecu" text="Imprimer reçu" />

    <!-- TABLE PAIEMENTS -->

    <Label layoutX="277.0" layoutY="320.0" style="-fx-font-size:16px;-fx-font-weight:bold;" text="Paiements enregistrés" />

    <TableView fx:id="tablePaiement" layoutX="277.0" layoutY="350.0" prefHeight="150" prefWidth="850">

        <columns>

            <TableColumn fx:id="colEleve" prefWidth="250" text="Élève" />

            <TableColumn fx:id="colFrais" prefWidth="200" text="Frais" />

            <TableColumn fx:id="colMontant" prefWidth="150" text="Montant" />

            <TableColumn fx:id="colDate" prefWidth="200" text="Date" />

        </columns>

    </TableView>

    <!-- TABLE TRANSACTIONS -->

    <Label layoutX="277.0" layoutY="510.0" style="-fx-font-size:16px;-fx-font-weight:bold;" text="Historique des transactions" />

    <TableView fx:id="tableTransaction" layoutX="277.0" layoutY="540.0" prefHeight="107.0" prefWidth="850">

        <columns>

            <TableColumn fx:id="colTransId" prefWidth="80" text="ID" />

            <TableColumn fx:id="colTransEleve" prefWidth="220" text="Élève" />

            <TableColumn fx:id="colTransMontant" prefWidth="150" text="Montant" />

            <TableColumn fx:id="colTransMode" prefWidth="150" text="Mode" />

            <TableColumn fx:id="colTransDate" prefWidth="200" text="Date" />

        </columns>

    </TableView>
   <Pane prefHeight="657.0" prefWidth="233.0" style="-fx-background-color: #2f4f4f;">
         <children>
            <Button layoutX="4.0" layoutY="218.0" onAction="#handleRapport" prefHeight="30.0" prefWidth="227.0" style="-fx-background-color: #2f4f4f;" text="RAPPORTS FINANCIERS" textFill="#f4ecec">
               <font>
                  <Font name="System Bold Italic" size="12.0" />
               </font>
            </Button>
            <FontAwesomeIcon fill="#fdf4f4" glyphName="USER" layoutX="95.0" layoutY="56.0" size="44" />
            <FontAwesomeIcon fill="#f2eded" glyphName="FILE_TEXT" layoutX="17.0" layoutY="242.0" size="16" />
            <Text fill="#f6f2f2" layoutX="55.0" layoutY="92.0" strokeType="OUTSIDE" strokeWidth="0.0" text="COMPTABLE">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Text>
            <Button layoutX="5.0" layoutY="176.0" onAction="#openScolarite" prefHeight="30.0" prefWidth="227.0" style="-fx-background-color: #2f4f4f;" text="SCOLARITE" textFill="#ede6e6">
               <font>
                  <Font name="System Bold Italic" size="12.0" />
               </font>
            </Button>
            <Button layoutX="4.0" layoutY="134.0" onAction="#OpenPaiement" prefHeight="30.0" prefWidth="227.0" style="-fx-background-color: #2f4f4f;" text="PAIEMENT ENSEIGNANTS" textFill="#f4ecec">
               <font>
                  <Font name="System Bold Italic" size="12.0" />
               </font>
            </Button>
            <FontAwesomeIcon fill="#ebeaea" glyphName="BANK" layoutX="18.0" layoutY="199.0" size="16" />
            <FontAwesomeIcon fill="#f4ecec" glyphName="USERS" layoutX="15.0" layoutY="157.0" size="16" />
            <Button layoutX="6.0" layoutY="257.0" onAction="#handleRapportScolaire" prefHeight="30.0" prefWidth="227.0" style="-fx-background-color: #2f4f4f;" text="RAPPORTS SCOLARITE" textFill="#f4ecec">
               <font>
                  <Font name="System Bold Italic" size="12.0" />
               </font>
            </Button>
            <FontAwesomeIcon fill="#f2eded" glyphName="FILE_TEXT" layoutX="19.0" layoutY="277.0" size="16" />
         </children>
      </Pane>
      <Button fx:id="btnDeconnexion" layoutX="3.0" layoutY="575.0" onAction="#handleLogout" prefHeight="30.0" prefWidth="227.0" style="-fx-background-color:#e74c3c; -fx-text-fill:white;" text="DECONNEXION" textFill="#f4f3f3">
         <font>
            <Font name="System Bold Italic" size="12.0" />
         </font>
      </Button>
      <FontAwesomeIcon fill="#ede9e9" glyphName="SIGN_OUT" layoutX="35.0" layoutY="601.0" size="20" />
   
      
</AnchorPane>
