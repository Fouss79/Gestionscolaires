<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="657.0" prefWidth="1283.0" style="-fx-background-image: url('/ressources/images/classroom.jpg'); -fx-background-size: cover; -fx-background-position: center;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.ClasseController">

    <!-- 🔹 Titre -->
    <Text fill="#295b8d" layoutX="253" layoutY="26" text="GESTION DES CLASSES">
        <font>
            <Font name="System Bold" size="20" />
        </font>
    </Text>

    <!-- 🔹 Sélection Niveau -->
    <Label layoutX="443" layoutY="130" text="Niveau">
        <font><Font name="System Bold" size="12" /></font>
    </Label>
    <ComboBox fx:id="cbNiveau" layoutX="520" layoutY="125" prefWidth="150" promptText="Choisir niveau" />

    <!-- 🔹 Sélection Série -->
    <Label layoutX="690" layoutY="130" text="Série">
        <font><Font name="System Bold" size="12" /></font>
    </Label>
    <ComboBox fx:id="cbSerie" layoutX="740" layoutY="125" prefWidth="150" promptText="Choisir serie" />

    <!-- 🔹 Sélection Groupe -->
    <Label layoutX="910" layoutY="130" text="Groupe">
        <font><Font name="System Bold" size="12" /></font>
    </Label>
    <ComboBox fx:id="cbGroupe" layoutX="970" layoutY="125" prefWidth="120" promptText="Choisir groupe" />

    <!-- 🔹 Boutons -->
    <Button fx:id="btnEnregistrer" layoutX="443" layoutY="180" onAction="#ajouterClasse" prefWidth="200" style="-fx-background-color: green;" text="ENREGISTRER" textFill="white">
        <font><Font name="System Bold" size="14" /></font>
    </Button>

    <Button layoutX="660" layoutY="180" onAction="#modifierClasse" prefWidth="130" style="-fx-background-color: gray;" text="MODIFIER" textFill="white" />

    <Button layoutX="810" layoutY="180" onAction="#supprimerClasse" prefWidth="130" style="-fx-background-color: red;" text="SUPPRIMER" textFill="white" />

    <!-- 🔹 Tableau des classes -->
    <TableView fx:id="tableClasses" layoutX="441" layoutY="230" prefHeight="400" prefWidth="820">
        <columns>
            <TableColumn fx:id="colNom" prefWidth="200" text="Classe" />
            <TableColumn fx:id="colNiveau" prefWidth="150" text="Niveau" />
            <TableColumn fx:id="colEffectif" prefWidth="150" text="Effectif" />
            <TableColumn fx:id="colFille" prefWidth="150" text="Filles" />
            <TableColumn fx:id="colGarcon" prefWidth="150" text="Garçons" /> <!-- fx:id sans accent -->
        </columns>
    </TableView>

</AnchorPane>
