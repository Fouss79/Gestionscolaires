<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="application.TarifController"
            prefWidth="800" prefHeight="500">

    <children>

        <!-- Titre -->
        <Label text="Gestion des Tarifs"
               style="-fx-font-size:20px; -fx-font-weight:bold;"
               AnchorPane.topAnchor="20"
               AnchorPane.leftAnchor="300"/>

        <!-- Motif -->
        <Label text="Motif :"
               AnchorPane.topAnchor="80"
               AnchorPane.leftAnchor="150"/>

        <ComboBox fx:id="cbMotif"
                  prefWidth="250"
                  AnchorPane.topAnchor="75"
                  AnchorPane.leftAnchor="220"/>

        <!-- Montant -->
        <Label text="Montant :"
               AnchorPane.topAnchor="130"
               AnchorPane.leftAnchor="150"/>

        <TextField fx:id="txtMontant"
                   promptText="Entrer le montant"
                   prefWidth="250"
                   AnchorPane.topAnchor="125"
                   AnchorPane.leftAnchor="220"/>

        <!-- Bouton -->
        <Button text="Enregistrer"
                onAction="#ajouterTarif"
                prefWidth="120"
                AnchorPane.topAnchor="170"
                AnchorPane.leftAnchor="350"/>

        <!-- TableView -->
        <TableView fx:id="tableTarifs"
                   prefWidth="700"
                   prefHeight="250"
                   AnchorPane.topAnchor="230"
                   AnchorPane.leftAnchor="50">

            <columns>
                <TableColumn fx:id="colMotif"
                             text="Motif"
                             prefWidth="230"/>

                <TableColumn fx:id="colAnnee"
                             text="Année scolaire"
                             prefWidth="230"/>

                <TableColumn fx:id="colMontant"
                             text="Montant"
                             prefWidth="230"/>
            </columns>

        </TableView>

    </children>
</AnchorPane>